# Connection string for PostgreSQL.
# When running via docker-compose.yml, the host is "postgres" (the service name).
# For local dev without Compose, use "localhost".
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/petrel

# Public origin of the panel. MUST match the URL you use in your browser.
# WARNING: Do NOT use http://127.0.0.1:3000 interchangeably with http://localhost:3000 —
# they are treated as different origins and will cause 403 CSRF errors on auth endpoints.
ORIGIN=http://localhost:3000

# Secret used by Better Auth for session signing. Use a long random string in production.
BETTER_AUTH_SECRET=your-secret-here

# Optional — fill in to enable GitHub OAuth login.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Comma-separated list of email addresses that receive admin privileges.
ADMIN_EMAILS=admin@admin.com

# Set to "true" in development to automatically seed admin@admin.com / admin on first start.
# WARNING: Disable this in production environments.
SEED_DEFAULT_ADMIN=true
